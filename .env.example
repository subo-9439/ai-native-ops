# ─── WoL Service ────────────────────────────────
WOL_SECRET=your-secret-key
# 멀티 타겟 설정 (Cloudflare Worker WOL_TARGETS env에도 동일하게 설정)
# WOL_TARGETS={"server1":{"mac":"9C-6B-00-57-89-16","ip":"211.184.10.138","label":"Windows PC"},"server2":{"mac":"XX-XX-XX-XX-XX-XX","ip":"211.184.10.138","label":"MacBook"}}
# 하위 호환 (server1만 쓸 경우)
PC_MAC=9C-6B-00-57-89-16
PC_PUBLIC_IP=211.184.10.138

# ─── Discord Bot ────────────────────────────────
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=

# ─── Discord #🚨-alerts 웹훅 (배포 알림) ───────
# SSOT: ~/.claude-sync/discord-alerts-webhook (chmod 600). env 변수가 설정되면 우선.
DISCORD_ALERTS_WEBHOOK=

# ─── Project Routing (swap per project) ─────────
# whosbuying:
GAME_SERVER_URL=http://localhost:8080
# other project:
# GAME_SERVER_URL=http://localhost:9090

ADMIN_API_KEY=
GITHUB_PAT=
GITHUB_REPO=

# ─── Claude ────────────────────────────────────
# Windows:
# CLAUDE_PROJECT_DIR=C:/Users/kws33/Desktop/projects/whosbuying
# Mac:
# CLAUDE_PROJECT_DIR=/Users/kimsubo/Desktop/game-project/whosbuying
CLAUDE_PROJECT_DIR=
